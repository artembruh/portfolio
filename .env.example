# =============================================================================
# Portfolio — artembratchenko.com
# Copy this file to .env and fill in real values before running docker compose up
# =============================================================================

# RPC endpoints — required for blockchain explorer functionality
# Replace with API-keyed URLs for production reliability (e.g., Alchemy, Infura)
ETH_RPC_URL=https://ethereum-rpc.publicnode.com
ETH_WS_URL=wss://ethereum-rpc.publicnode.com
BASE_RPC_URL=https://base-rpc.publicnode.com
BASE_WS_URL=wss://base-rpc.publicnode.com
BSC_RPC_URL=https://bsc-rpc.publicnode.com
BSC_WS_URL=wss://bsc-rpc.publicnode.com
SOLANA_RPC_URL=https://solana-rpc.publicnode.com
SOLANA_WS_URL=wss://solana-rpc.publicnode.com

# Backend port (optional — defaults to 3000)
PORT=3000

# WebSocket CORS origin — production domain or '*' for all origins (dev)
# In production: set to https://artembratchenko.com
# In dev: leave unset (defaults to '*')
WS_CORS_ORIGIN=https://artembratchenko.com
