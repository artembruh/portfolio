# RPC endpoints — required for blockchain explorer functionality
# Replace with API-keyed URLs for production reliability (e.g., Alchemy, Infura)
ETH_RPC_URL=https://eth-mainnet.public.blastapi.io
ETH_WS_URL=wss://eth-mainnet.public.blastapi.io
BASE_RPC_URL=https://mainnet.base.org
BASE_WS_URL=wss://mainnet.base.org
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_WS_URL=wss://bsc-dataseed.binance.org
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Backend port (optional — defaults to 3000)
PORT=3000
